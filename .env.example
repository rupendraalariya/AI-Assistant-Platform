# Application
APP_NAME=LLM Chatbot Assistant
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ===== Multi-Provider API Keys =====
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Default provider (openai, gemini, claude, groq, deepseek, mistral, together, ollama)
DEFAULT_PROVIDER=openai

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chatbot_db
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/chatbot_db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=86400

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3000
SESSION_SECRET_KEY=change-this-session-secret-in-production

# HuggingFace Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# FAISS
FAISS_INDEX_PATH=./data/faiss_index

# RAG Configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
